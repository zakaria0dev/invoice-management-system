generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
  CREDITED
  SETTLED_WITH_RETURNS
}

model User {
  id        BigInt   @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  avatarUrl String?
  roleId    BigInt   @default(1)
  role      UserRole @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  creditNotes CreditNote[]
  payments    Payment[]
  refunds     Refund[]
  auditLogs   AuditLog[]
}

model Client {
  id            BigInt       @id @default(autoincrement())
  name          String       // Raison sociale
  email         String
  phone         String?
  address       String?
  ice           String?      // Identifiant Commun de l'Entreprise
  creditBalance Decimal      @default(0) @db.Decimal(10, 2)
  autoApplyCredit Boolean    @default(true)
  invoices      Invoice[]
  quotes        Quote[]
  creditNotes   CreditNote[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Invoice {
  id          BigInt        @id @default(autoincrement())
  number      String        @unique
  date        DateTime      @default(now())
  dueDate     DateTime
  status      InvoiceStatus @default(DRAFT)
  total       Decimal       @db.Decimal(10, 2)
  notes       String?
  clientId    BigInt
  client      Client        @relation(fields: [clientId], references: [id])
  items       InvoiceItem[]
  payments    Payment[]
  creditNotes CreditNote[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  signature   String?       // Base64 or URL to signature image
  currency    String        @default("MAD")
  terms       String?
  legalMentions String?
  remindersEnabled Boolean    @default(true)
  isCancelled      Boolean    @default(false)
  stockMovements   StockMovement[]
  paymentTracker   InvoicePaymentTracker?
  refunds          Refund[]

  // Voiding metadata
  voidReason         String?
  voidedBy           BigInt?
  voidedAt           DateTime?

  // Currency and tax tracking
  originalCurrency   String         @default("MAD")
  exchangeRate       Float?         @default(1.0)
  taxBreakdown       Json           @default("[]")
  metadata           Json?          @default("{}")

  creditApplications CreditApplication[]
}

model Quote {
  id          BigInt    @id @default(autoincrement())
  number      String    @unique
  date        DateTime  @default(now())
  validUntil  DateTime
  status      String    @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, CONVERTED
  total       Decimal   @db.Decimal(10, 2)
  notes       String?
  clientId    BigInt
  client      Client    @relation(fields: [clientId], references: [id])
  items       QuoteItem[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  signature   String?   // Digital signature
  signatureDate DateTime?
  signatureIp String?
  linkedInvoiceId BigInt?
  currency    String    @default("MAD")
  isCancelled   Boolean   @default(false)
  stockMovements StockMovement[]
}

model InvoiceItem {
  id          BigInt   @id @default(autoincrement())
  description String
  quantity    Int
  price       Decimal  @db.Decimal(10, 2)
  tax         Decimal  @default(0) @db.Decimal(10, 2)
  discount    Decimal  @default(0) @db.Decimal(10, 2)
  discountType String  @default("PERCENTAGE") // "PERCENTAGE", "AMOUNT"
  invoiceId   BigInt
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   BigInt?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model QuoteItem {
  id          BigInt   @id @default(autoincrement())
  description String
  quantity    Int
  price       Decimal  @db.Decimal(10, 2)
  tax         Decimal  @default(0) @db.Decimal(10, 2)
  discount    Decimal  @default(0) @db.Decimal(10, 2)
  discountType String  @default("PERCENTAGE") // "PERCENTAGE", "AMOUNT"
  quoteId     BigInt
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId   BigInt?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Product {
  id          BigInt          @id @default(autoincrement())
  name        String
  description String?
  priceHT     Decimal         @db.Decimal(10, 2)
  tva         Decimal         @db.Decimal(10, 2)
  unit        String?
  category    String?
  stock       Int?            @default(0)
  minStock    Int?            @default(0)
  imageUrl    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  movements   StockMovement[]
  invoiceItems InvoiceItem[]
  quoteItems   QuoteItem[]
  creditNoteItems CreditNoteItem[]
}

model StockMovement {
  id          BigInt   @id @default(autoincrement())
  productId   BigInt
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Int      // positive for addition, negative for deduction
  type        String   // e.g. "MANUAL", "INVOICE"
  note        String?
  createdAt   DateTime @default(now())
  invoiceId   BigInt?
  quoteId     BigInt?
  invoice     Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  quote       Quote?   @relation(fields: [quoteId], references: [id], onDelete: SetNull)
}

model InvoicePaymentTracker {
  id               BigInt        @id @default(autoincrement())
  invoiceId        BigInt        @unique
  invoice          Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  totalAmount      Decimal       @db.Decimal(10, 2)
  paidAmount       Decimal       @db.Decimal(10, 2)
  remainingAmount  Decimal       @db.Decimal(10, 2)
  status           String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model CompanySettings {
  id             BigInt   @id @default(autoincrement())
  name           String
  logo           String?
  logoUrl        String?
  address        String?
  email          String?
  phone          String?
  iban           String?
  tvaNumber      String?
  defaultTVARate Decimal? @db.Decimal(10, 2)
  currency       String   @default("MAD")
  smtpHost       String?
  smtpPort       Int?
  smtpUser       String?
  smtpPass       String?
  defaultTerms   String?
  defaultNotes   String?
  legalMentions  String?
  pdfTheme       String   @default("MODERN")
}

model CreditNote {
  id          BigInt   @id @default(autoincrement())
  number      String   @unique
  date        DateTime @default(now())
  clientId    BigInt
  client      Client   @relation(fields: [clientId], references: [id])
  invoiceId   BigInt
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  type        String   @default("FULL") // "ITEM", "PARTIAL", "FULL"
  total       Decimal  @db.Decimal(10, 2)
  taxAmount   Decimal  @default(0) @db.Decimal(10, 2)
  notes       String?
  status      String   @default("DRAFT") // "DRAFT", "ISSUED", "APPLIED", "PARTIALLY_APPLIED", "REFUNDED"
  resolution  String?  // "Reduce_Balance", "Refund", "Customer_Credit", "Partially_Applied", "To_Be_Decided"
  userId      BigInt?
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       CreditNoteItem[]
  payments    Payment[]

  // Enhanced fields
  originalInvoiceTotal Decimal           @default(0) @db.Decimal(10, 2)
  remainingAmount      Decimal           @default(0) @db.Decimal(10, 2)
  expiryDate           DateTime? 
  taxCalculationMethod String            @default("Original_Rates")
  reversalOf           BigInt? 

  appliedToInvoices    CreditApplication[]
}

model CreditNoteItem {
  id          BigInt   @id @default(autoincrement())
  description String
  quantity    Int
  price       Decimal  @db.Decimal(10, 2)
  tax         Decimal  @default(0) @db.Decimal(10, 2)
  creditNoteId BigInt
  creditNote  CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  productId   BigInt?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Payment {
  id        BigInt   @id @default(autoincrement())
  amount    Decimal  @db.Decimal(10, 2)
  date      DateTime @default(now())
  method    String   // CASH, BANK_TRANSFER, CHECK, etc.
  invoiceId BigInt?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  creditNoteId BigInt?
  creditNote   CreditNote? @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  isRefund     Boolean     @default(false)
  refundId     BigInt?
  refund       Refund?     @relation(fields: [refundId], references: [id])
  userId       BigInt?
  user         User?       @relation(fields: [userId], references: [id])
}

model Refund {
  id          BigInt       @id @default(autoincrement())
  date        DateTime     @default(now())
  amount      Decimal      @db.Decimal(10, 2)
  reason      String?
  invoiceId   BigInt
  invoice     Invoice      @relation(fields: [invoiceId], references: [id])
  items       RefundItem[]
  payments    Payment[]
  userId      BigInt?
  user        User?        @relation(fields: [userId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  metadata    Json?        @default("{}")
}

model RefundItem {
  id          BigInt   @id @default(autoincrement())
  refundId    BigInt
  refund      Refund   @relation(fields: [refundId], references: [id], onDelete: Cascade)
  productId   BigInt?
  description String
  quantity    Int
  price       Decimal  @db.Decimal(10, 2)
}

model ProductHistory {
  id          BigInt   @id @default(autoincrement())
  productId   BigInt
  productName String
  action      String   // CREATE, UPDATE, DELETE, STOCK_ADJUST
  changes     Json?    // Detailed diff for updates
  userId      BigInt?  // Person who made the change
  createdAt   DateTime @default(now())
}

model CreditApplication {
  id              BigInt   @id @default(autoincrement())
  creditNoteId    BigInt
  creditNote      CreditNote @relation(fields: [creditNoteId], references: [id])
  invoiceId       BigInt? 
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id])
  amount          Decimal  @db.Decimal(10, 2)
  appliedAt       DateTime @default(now())
  appliedBy       BigInt
  type            String   // INVOICE, LEDGER, REFUND

  @@unique([creditNoteId, invoiceId])
}

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  action     String   // e.g., "INVOICE_VOIDED", "LOGIN_SUCCESS"
  entityId   BigInt?
  entityType String?  // e.g., "INVOICE", "USER"
  details    Json?
  userId     BigInt?
  user       User?    @relation(fields: [userId], references: [id])
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model Permission {
  id          BigInt     @id @default(autoincrement())
  name        String     @unique // e.g., "invoices.create", "users.manage"
  description String?
  category    String     // e.g., "Invoices", "Users", "Reports"
  rolePermissions RolePermission[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model UserRole {
  id          BigInt     @id @default(autoincrement())
  name        String     @unique // e.g., "Admin", "Accountant", "Sales Manager"
  description String?
  isSystem    Boolean    @default(false) // System roles cannot be deleted
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model RolePermission {
  id           BigInt      @id @default(autoincrement())
  roleId       BigInt
  permissionId BigInt
  role         UserRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())

  @@unique([roleId, permissionId])
}
